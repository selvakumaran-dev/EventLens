# ── Backend API ──────────────────────────────────────────────────────────────
# In production set this to your Render/Railway backend URL.
# In dev, the Vite proxy forwards /api → localhost:5000 automatically.
VITE_API_URL=

# ── face-api.js Models ───────────────────────────────────────────────────────
# Leave blank to use jsDelivr CDN (default).
# Set to "/models" if you've downloaded model files into /public/models/.
VITE_FACE_API_MODEL_URL=

# ── Cloudinary ───────────────────────────────────────────────────────────────
# Your Cloudinary cloud name (e.g. "my-cloud")
VITE_CLOUDINARY_CLOUD_NAME=

# An UNSIGNED upload preset created in Cloudinary dashboard → Settings → Upload
VITE_CLOUDINARY_UPLOAD_PRESET=
